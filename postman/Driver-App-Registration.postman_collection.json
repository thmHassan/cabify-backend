{
  "info": {
    "name": "Cabify Driver App Registration",
    "_postman_id": "c1d0d5e3-89d5-4c21-9f4e-3039ea000101",
    "description": "Driver mobile app registration/auth flow with companyCode-aware tenant resolution, multipart signup, and login APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "company_code",
      "value": "company013"
    },
    {
      "key": "database",
      "value": "company013"
    },
    {
      "key": "driver_token",
      "value": ""
    },
    {
      "key": "email",
      "value": "driver@example.com"
    },
    {
      "key": "phone",
      "value": "3001234567"
    },
    {
      "key": "country_code",
      "value": "+92"
    },
    {
      "key": "vehicle_type_id",
      "value": "1"
    },
    {
      "key": "vehicle_color",
      "value": "White"
    },
    {
      "key": "vehicle_seats",
      "value": "4"
    },
    {
      "key": "plate_no",
      "value": "ABC-123"
    },
    {
      "key": "vehicle_registration_date",
      "value": "2024-01-15"
    }
  ],
  "item": [
    {
      "name": "Public Registration Flow",
      "item": [
        {
          "name": "Verify Company Code",
          "request": {
            "method": "GET",
            "header": [
              { "key": "companyCode", "value": "{{company_code}}" }
            ],
            "url": {
              "raw": "{{base_url}}/driver/verify-company-code?companyCode={{company_code}}",
              "host": ["{{base_url}}"],
              "path": ["driver", "verify-company-code"],
              "query": [
                {
                  "key": "companyCode",
                  "value": "{{company_code}}"
                }
              ]
            },
            "description": "Verify if the company code is valid before starting driver registration."
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"email\": \"{{email}}\",\n  \"phone\": \"{{phone}}\",\n  \"countryCode\": \"{{country_code}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/driver/check-availability"
          }
        },
        {
          "name": "Document Requirements",
          "request": {
            "method": "GET",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" }
            ],
            "url": {
              "raw": "{{base_url}}/driver/document-requirements?database={{database}}&companyCode={{company_code}}",
              "host": ["{{base_url}}"],
              "path": ["driver", "document-requirements"],
              "query": [
                {
                  "key": "database",
                  "value": "{{database}}"
                },
                {
                  "key": "companyCode",
                  "value": "{{company_code}}"
                }
              ]
            }
          }
        },
        {
          "name": "Vehicle Type List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" }
            ],
            "url": {
              "raw": "{{base_url}}/driver/vehicle-type-list?database={{database}}&companyCode={{company_code}}",
              "host": ["{{base_url}}"],
              "path": ["driver", "vehicle-type-list"],
              "query": [
                {
                  "key": "database",
                  "value": "{{database}}"
                },
                {
                  "key": "companyCode",
                  "value": "{{company_code}}"
                }
              ]
            }
          }
        },
        {
          "name": "Driver App Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "companyCode", "value": "{{company_code}}", "type": "text" },
                { "key": "firstName", "value": "John", "type": "text" },
                { "key": "lastName", "value": "Driver", "type": "text" },
                { "key": "email", "value": "{{email}}", "type": "text" },
                { "key": "password", "value": "Driver@123", "type": "text" },
                { "key": "confirmPassword", "value": "Driver@123", "type": "text" },
                { "key": "phone", "value": "{{phone}}", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "dob", "value": "1998-05-10", "type": "text" },
                { "key": "address", "value": "Street 12, Islamabad", "type": "text" },
                { "key": "city", "value": "Islamabad", "type": "text" },
                { "key": "country", "value": "Pakistan", "type": "text" },
                { "key": "countryCode", "value": "{{country_code}}", "type": "text" },
                { "key": "vehicle_type_id", "value": "{{vehicle_type_id}}", "type": "text" },
                { "key": "color", "value": "{{vehicle_color}}", "type": "text" },
                { "key": "seats", "value": "{{vehicle_seats}}", "type": "text" },
                { "key": "plate_no", "value": "{{plate_no}}", "type": "text" },
                { "key": "vehicle_registration_date", "value": "{{vehicle_registration_date}}", "type": "text" },
                { "key": "deviceToken", "value": "driver-device-token-001", "type": "text" },
                { "key": "fcmToken", "value": "driver-fcm-token-001", "type": "text" },
                { "key": "documentKeys", "value": "[\"license_front\",\"license_back\",\"vehicle_registration\"]", "type": "text" },
                { "key": "photo", "type": "file", "src": "" },
                { "key": "documents", "type": "file", "src": "" },
                { "key": "documents", "type": "file", "src": "" },
                { "key": "documents", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/driver/register"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Driver Login With Email Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"Driver@123\",\n  \"deviceToken\": \"driver-device-token-001\",\n  \"fcmToken\": \"driver-fcm-token-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/driver/login"
          }
        },
        {
          "name": "Driver Login By Phone Check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"phone\": \"{{phone}}\",\n  \"country_code\": \"{{country_code}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/driver/login"
          }
        },
        {
          "name": "Driver Verify Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"phone\": \"{{phone}}\",\n  \"country_code\": \"{{country_code}}\",\n  \"password\": \"Driver@123\",\n  \"device_token\": \"driver-device-token-001\",\n  \"fcm_token\": \"driver-fcm-token-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/driver/verify-password"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "database", "value": "{{database}}" },
              { "key": "companyCode", "value": "{{company_code}}" },
              { "key": "Authorization", "value": "Bearer {{driver_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/driver/refresh-token?companyCode={{company_code}}",
              "host": ["{{base_url}}"],
              "path": ["driver", "refresh-token"],
              "query": [
                {
                  "key": "companyCode",
                  "value": "{{company_code}}"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
